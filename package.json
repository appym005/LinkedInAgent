{
  "name": "linkedin-agent",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:backend": "npm run build -w @linkedin-agent/backend",
    "build:frontend": "npm run build -w @linkedin-agent/frontend",
    "dev:backend": "npm run dev -w @linkedin-agent/backend",
    "dev:frontend": "npm run dev -w @linkedin-agent/frontend"
  }
}
